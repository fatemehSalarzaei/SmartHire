{
  "name": "Customer Support Screening With AI Signals",
  "version": 1,
  "kando_job_id": 2001,
  "default_missing_data_policy": "NEEDS_REVIEW",
  "scoring_enabled": true,
  "max_score": 100,
  "groups": [
    {
      "name": "Required gates",
      "group_type": "GATE",
      "logic": "ALL",
      "priority": 1,
      "rules": [
        {
          "name": "Age must be 22-35",
          "rule_type": "REJECT_GATE",
          "target_entity": "candidate",
          "target_fields": [
            "age"
          ],
          "operator": "NOT_BETWEEN",
          "values": [
            22,
            35
          ],
          "reason_template": "سن خارج از بازه مجاز است",
          "on_missing_policy": "NEEDS_REVIEW"
        },
        {
          "name": "English must be Advanced",
          "rule_type": "PASS_GATE",
          "target_entity": "language",
          "target_fields": [
            "english_level"
          ],
          "operator": "EQUALS",
          "values": [
            "Advanced"
          ],
          "reason_template": "زبان انگلیسی پیشرفته",
          "on_missing_policy": "NEEDS_REVIEW"
        }
      ]
    },
    {
      "name": "Related experience",
      "group_type": "OVERRIDE",
      "logic": "ANY",
      "priority": 2,
      "rules": [
        {
          "name": "Customer support experience",
          "rule_type": "PASS_GATE",
          "target_entity": "work",
          "target_fields": [
            "role_title",
            "description",
            "job_category"
          ],
          "operator": "CONTAINS_ANY",
          "values": [
            "Customer Support",
            "پشتیبانی",
            "Customer Service"
          ],
          "reason_template": "سابقه مرتبط پشتیبانی مشتری",
          "score_delta": 25
