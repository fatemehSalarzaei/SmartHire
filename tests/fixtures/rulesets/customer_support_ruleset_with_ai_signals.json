          ],
          "score_delta": 15,
          "reason_template": "دانشگاه هدف"
        },
        {
          "name": "Target field bonus",
          "rule_type": "SCORE_BONUS",
          "target_entity": "education",
          "target_fields": [
            "field_name"
          ],
          "operator": "FUZZY_IN",
          "values": [
            "زبان انگلیسی",
